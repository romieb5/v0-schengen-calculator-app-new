# =============================================================================
# Environment Variables — Schengen Monitor
# =============================================================================
# Copy to .env and fill in real values. NEVER commit .env to version control.
#
# PRODUCTION REQUIREMENTS:
# - All URLs must use HTTPS
# - BETTER_AUTH_SECRET must be a cryptographically random string (≥32 chars)
# - DATABASE_URL should use SSL (?sslmode=require) and restrict access to
#   your deployment IP range via Supabase network restrictions
# - Stripe webhook endpoint must be configured in the Stripe dashboard
# =============================================================================

# Supabase
# In production, append ?sslmode=require to enforce encrypted DB connections
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# BetterAuth
# BETTER_AUTH_SECRET: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=your-random-32-char-secret-here
# In production, set to your HTTPS domain (e.g., https://www.schengenmonitor.com)
BETTER_AUTH_URL=http://localhost:3000

# Resend (email delivery)
RESEND_API_KEY=re_...

# Stripe (payments)
STRIPE_SECRET_KEY=sk_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Upstash Redis (rate limiting)
# Required for production. Without these, rate limiting falls back to in-memory
# (which resets on deploy and doesn't work across serverless instances).
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://[NAME].upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
